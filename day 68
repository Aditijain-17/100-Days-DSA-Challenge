Problem: Implement topological sorting using in-degree array and queue (Kahnâ€™s Algorithm).

  #include <stdio.h>
#include <stdlib.h>

#define MAX 1000

int adj[MAX][MAX], indegree[MAX], queue[MAX], result[MAX];
int V;

int main() {
    int E;
    scanf("%d %d", &V, &E);

    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        indegree[v]++;
    }

    int front = 0, rear = 0;

    for (int i = 0; i < V; i++) {
        if (indegree[i] == 0) {
            queue[rear++] = i;
        }
    }

    int idx = 0;

    while (front < rear) {
        int node = queue[front++];
        result[idx++] = node;

        for (int i = 0; i < V; i++) {
            if (adj[node][i]) {
                indegree[i]--;
                if (indegree[i] == 0) {
                    queue[rear++] = i;
                }
            }
        }
    }

    if (idx != V) {
        printf("Cycle exists");
    } else {
        for (int i = 0; i < V; i++) {
            printf("%d ", result[i]);
        }
    }

    return 0;
}
