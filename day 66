Problem: Detect cycle in directed graph using DFS and recursion stack.

#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

int adj[MAX][MAX], vis[MAX], path[MAX];
int V;

int dfs(int node) {
    vis[node] = 1;
    path[node] = 1;

    for (int i = 0; i < V; i++) {
        if (adj[node][i]) {
            if (!vis[i]) {
                if (dfs(i)) return 1;
            } else if (path[i]) {
                return 1;
            }
        }
    }
    path[node] = 0;
    return 0;
}
int main() {
    int E;
    scanf("%d %d", &V, &E);

    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
    }

    for (int i = 0; i < V; i++) {
        if (!vis[i]) {
            if (dfs(i)) {
                printf("YES");
                return 0;
            }
        }
    }

    printf("NO");
    return 0;
}
