Problem Statement:
Given a queue of integers, reverse the queue using a stack.

#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int queue[n], stack[n];
    int front = 0, rear = 0, top = -1;

    for (int i = 0; i < n; i++)
        scanf("%d", &queue[rear++]);

    while (front < rear)
        stack[++top] = queue[front++];

    front = 0;
    rear = 0;

    while (top >= 0)
        queue[rear++] = stack[top--];

    for (int i = 0; i < n; i++)
        printf("%d ", queue[i]);

    return 0;
}
