Problem: Print topological ordering of a Directed Acyclic Graph (DAG) using DFS

  #include <stdio.h>
#include <stdlib.h>

#define MAX 1000

int adj[MAX][MAX], vis[MAX], stack[MAX];
int top = -1, V;

void dfs(int node) {
    vis[node] = 1;

    for (int i = 0; i < V; i++) {
        if (adj[node][i] && !vis[i]) {
            dfs(i);
        }
    }

    stack[++top] = node;
}

int main() {
    int E;
    scanf("%d %d", &V, &E);

    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
    }

    for (int i = 0; i < V; i++) {
        if (!vis[i]) {
            dfs(i);
        }
    }

    while (top >= 0) {
        printf("%d ", stack[top--]);
    }

    return 0;
}
