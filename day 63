Problem: Perform DFS starting from a given source vertex using recursion.

#include <stdio.h>
#define MAX 100
int visited[MAX];
int adj[MAX][MAX];
int n;
void dfs(int v) {
    printf("%d ", v);
    visited[v] = 1;
    for (int i = 0; i < n; i++) {
        if (adj[v][i] == 1 && visited[i] == 0) {
            dfs(i);
        }
    }
}

int main() {
    int s;

    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    for (int i = 0; i < n; i++) {
        visited[i] = 0;
    }

    scanf("%d", &s);

    dfs(s);

    return 0;
}
